# Nexus Night Shift Agent — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# Anthropic API key (for Claude Sonnet — complex reasoning tasks)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (for Hermes 3 70B — routine tasks)
OPENROUTER_API_KEY=sk-or-...

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=...

# Telegram user ID to restrict bot access to (get via @userinfobot)
TELEGRAM_ALLOWED_USER_ID=...

# Workspace root (default: /workspace)
WORKSPACE_ROOT=/workspace

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
