# Nexus Night Shift Agent — Environment Variables

# Copy to /etc/nexus-agent.env and fill in values. NEVER commit secrets.

# Anthropic API key (Claude Sonnet — all task execution)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=...

# Telegram user ID to restrict bot access to (get via @userinfobot)
TELEGRAM_ALLOWED_USER_ID=...

# Workspace root (default: /workspace)
WORKSPACE_ROOT=/workspace

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Spend ceilings — agent stops starting new tasks if cumulative night spend
# exceeds NIGHT_SPEND_CEILING_USD; warns if a single task exceeds TASK_SPEND_CEILING_USD.
# Both are in USD.
NIGHT_SPEND_CEILING_USD=5.00
TASK_SPEND_CEILING_USD=3.00
