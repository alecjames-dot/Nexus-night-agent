# Never commit secrets
.env
/etc/nexus-agent.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Runtime output contents (directories tracked via .gitkeep, contents are not)
workspace/output/*
workspace/briefs/*
!workspace/output/.gitkeep
!workspace/briefs/.gitkeep

# Logs
*.log

# OS
.DS_Store
Thumbs.db
